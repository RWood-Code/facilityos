{
  "name": "facilityos",
  "version": "1.1.0",
  "description": "Aquatic & recreation facility operations — multi-terminal, installable",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "dev:server": "node server/index.js",
    "dev:web": "concurrently -k \"npm run dev:server\" \"vite\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder --win --x64",
    "dist:dir": "npm run build && electron-builder --win --x64 --dir",
    "server": "node server/index.js",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "electron-builder install-app-deps",
    "predist": "npm run rebuild:electron"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "express": "^4.21.2",
    "lucide-react": "^0.383.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "nz.facility.facilityos",
    "productName": "FacilityOS",
    "directories": { "output": "dist-electron" },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "shared/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FacilityOS",
      "installerLanguages": ["en_US"],
      "license": null
    }
  }
}
